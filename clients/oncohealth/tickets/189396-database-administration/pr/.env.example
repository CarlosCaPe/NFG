# .env.example — copy to .env and fill in values for local development
# NEVER commit .env — it is gitignored.
# For CI/CD, these come from ADO variable group 'newum-db-{env}'.

# PostgreSQL connection (privatelink — only reachable from windows365 CPC or Azure network)
DB_HOST=fcc9bae56d16.privatelink.postgres.database.azure.com
DB_PORT=5432

# Dev database
DB_NAME=newum_dev

# Migration runner credentials (has DDL privileges)
# Ask DevOps (Luiyi) for the newum_migrations user credentials.
DB_MIGRATIONS_USER=newum_migrations
DB_MIGRATIONS_PASSWORD=REPLACE_ME

# App credentials (DML only — for verifying role grants after migration)
DB_APP_USER=newum_dev
DB_APP_PASSWORD=REPLACE_ME
